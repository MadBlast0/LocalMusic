{
  "name": "local-music",
  "version": "1.0.0",
  "description": "A modern, open-source desktop music downloader built with Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "keywords": [
    "music",
    "downloader",
    "electron",
    "music-downloader",
    "audio",
    "mp3",
    "desktop-app",
    "cross-platform"
  ],
  "author": "Local Music Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MadBlast0/local-music.git"
  },
  "bugs": {
    "url": "https://github.com/MadBlast0/local-music/issues"
  },
  "homepage": "https://github.com/MadBlast0/local-music#readme",
  "build": {
    "appId": "com.localmusic.app",
    "productName": "Local Music",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "donate.html",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": ["nsis"],
      "sign": null,
      "icon": "build/app-icon.svg"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.music",
      "identity": null,
      "icon": "build/app-icon.svg"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Audio",
      "icon": "build/app-icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/app-icon.svg",
      "uninstallerIcon": "build/app-icon.svg"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
